			</Component>
			<Component Guid="2152c1e9-8ba1-57d4-96e5-847c3067bede" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/auth-gitlab.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="08f20af5-373e-5cbf-a0af-ac555e3bb938" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/auth-google.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="c65b5667-9e2c-5d85-99a5-cf1ad3829a8c" Subdirectory="data\flutter_assets\assets">
