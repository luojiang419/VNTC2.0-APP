			</Component>
			<Component Guid="721a989c-7da8-56d2-ada2-19792822209b" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/device_group.ttf" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="5cffc8dd-e7c6-5b69-88f8-4cca8ece17e0" Subdirectory="data\flutter_assets\assets">
