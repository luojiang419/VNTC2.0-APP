			</Component>
			<Component Guid="ca532fe5-0078-5b02-9060-b95e9e0e00e2" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/chat.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="8446e9cc-02e8-5f8e-a4d7-fd94b11d041b" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/chat2.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="77c18163-b458-5cc7-9238-06c5f222a0d9" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/checkbox-outline.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="5f338545-18c1-5741-9214-d88a011bc478" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/chevron_up_chevron_down.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="ad2526ca-c586-5630-bf06-4a7cb9f4058b" Subdirectory="data\flutter_assets\assets">
