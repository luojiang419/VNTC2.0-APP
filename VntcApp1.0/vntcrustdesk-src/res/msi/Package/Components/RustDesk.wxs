			</Component>
			<Component Guid="e053dcbb-86bd-4a5c-9e66-b9560c0b2ea6" Subdirectory="data\flutter_assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/FontManifest.json" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="14861866-ce30-49f3-bedc-4ac8b02fe70d" Subdirectory="data\flutter_assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/NativeAssetsManifest.json" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="b911be64-d995-4d67-a804-81d5005a334e" Subdirectory="data\flutter_assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/NOTICES.Z" KeyPath="yes" Checksum="yes" />
