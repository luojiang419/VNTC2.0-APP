			</Component>
			<Component Guid="66a33ff3-a5fa-4410-bea0-09eb22318a89" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/auth-gitlab.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="a82862c9-7d30-44db-aead-c29e604e59fa" Subdirectory="data\flutter_assets\assets">
