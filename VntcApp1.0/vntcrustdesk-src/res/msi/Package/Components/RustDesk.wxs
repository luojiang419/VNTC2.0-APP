			</Component>
			<Component Guid="f3bcfa82-492a-4258-ac47-ee378a3d8051" Subdirectory="data">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/icudtl.dat" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="97c5cd0b-86bf-4509-ac61-4561bf712c22" Subdirectory="usbmmidd_v2">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/usbmmidd_v2/idd_instructions.txt" KeyPath="yes" Checksum="yes" />
			</Component>
