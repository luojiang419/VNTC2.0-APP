			</Component>
			<Component Guid="20893308-c15e-4266-9584-f6b38d21a753" >
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/flutter_custom_cursor_plugin.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="b2dccc8b-c422-4f80-a5de-ef1cb700e5d9" >
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/flutter_gpu_texture_renderer_plugin.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="94ecb8d2-b256-467b-a0a9-fff02656ec9d" >
