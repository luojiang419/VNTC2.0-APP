			</Component>
			<Component Guid="044f46c9-2721-5712-a8c7-c5fbdfdd2f1d" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/VntcApp1.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/home.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="74b420dc-39e2-51e4-84ac-f81606b83d22" Subdirectory="data\flutter_assets\assets">
